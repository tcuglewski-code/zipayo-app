generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SwiftTapUser {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  businessName  String?
  role          String    @default("user") // user, admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  paymentLinks  SwiftTapPaymentLink[]
  transactions  SwiftTapTransaction[]
  merchant      Merchant?

  @@map("swifttap_users")
}

model SwiftTapPaymentLink {
  id          String   @id @default(cuid())
  userId      String
  amount      Float?   // null = variable amount
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  user         SwiftTapUser          @relation(fields: [userId], references: [id])
  transactions SwiftTapTransaction[]

  @@map("swifttap_payment_links")
}

model SwiftTapTransaction {
  id              String   @id @default(cuid())
  paymentLinkId   String
  userId          String
  amount          Float
  currency        String   @default("eur")
  status          String   // pending, succeeded, failed
  stripePaymentId String?
  customerEmail   String?
  createdAt       DateTime @default(now())
  
  paymentLink SwiftTapPaymentLink @relation(fields: [paymentLinkId], references: [id])
  user        SwiftTapUser        @relation(fields: [userId], references: [id])

  @@map("swifttap_transactions")
}

// ============================================================
// SwiftTap L2 Models - Stripe Connect, Analytics, Team
// ============================================================

model Merchant {
  id                 String       @id @default(cuid())
  userId             String       @unique
  businessName       String
  businessType       String?
  stripeAccountId    String?      // Stripe Connect Account ID
  stripeOnboarded    Boolean      @default(false)
  platformFeePercent Float        @default(0.5)
  active             Boolean      @default(true) // S17: Merchant deaktivieren
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  
  user               SwiftTapUser @relation(fields: [userId], references: [id])
  payments           Payment[]
  qrCodes            QRCode[]
  teamMembers        TeamMember[]
  apiKeys            ApiKey[]

  @@map("merchants")
}

model Payment {
  id              String    @id @default(cuid())
  merchantId      String
  stripePaymentId String?   @unique
  amount          Int       // in cents
  currency        String    @default("eur")
  status          String    // pending, succeeded, failed, refunded
  description     String?
  customerEmail   String?
  qrCodeId        String?
  platformFee     Int?      // S18: Platform-Fee in Cents
  expiresAt       DateTime? // S19: Expiration für API-Zahlungen
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  paidAt          DateTime? // S19: Zeitpunkt der Zahlung
  refundedAt      DateTime? // S19: Zeitpunkt der Rückerstattung
  
  merchant        Merchant  @relation(fields: [merchantId], references: [id])
  qrCode          QRCode?   @relation(fields: [qrCodeId], references: [id])

  @@map("payments")
}

model QRCode {
  id          String    @id @default(cuid())
  merchantId  String
  name        String
  amount      Int?      // null = variable amount
  currency    String    @default("eur")
  description String?
  isActive    Boolean   @default(true)
  uses        Int       @default(0)
  createdAt   DateTime  @default(now())
  
  merchant    Merchant  @relation(fields: [merchantId], references: [id])
  payments    Payment[]

  @@map("qr_codes")
}

model TeamMember {
  id          String   @id @default(cuid())
  merchantId  String
  email       String
  role        String   @default("member") // owner, admin, member
  inviteToken String?  @unique
  accepted    Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  merchant    Merchant @relation(fields: [merchantId], references: [id])

  @@map("team_members")
}

// ============================================================
// SwiftTap L4 - API Keys für POS-Integration
// ============================================================

model ApiKey {
  id          String    @id @default(cuid())
  merchantId  String
  key         String    @unique
  name        String
  lastUsed    DateTime?
  createdAt   DateTime  @default(now())
  
  merchant    Merchant  @relation(fields: [merchantId], references: [id])

  @@map("api_keys")
}
