# ==============================================
# Zipayo Environment Variables
# ==============================================
# Kopiere diese Datei zu .env und fülle die Werte aus
# Für lokales Testing: kopiere zu .env.test
# Siehe docs/STAGING-SETUP.md für vollständige Anleitung

# Database (Neon PostgreSQL)
# Für Staging: Neon Test-Branch nutzen
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# NextAuth.js
# NEXTAUTH_SECRET: Generiere mit: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# App URL (for emails, sitemap, schema.org)
NEXT_PUBLIC_APP_URL="https://swifttap-app.vercel.app"

# Stripe API Keys
# Hole von: https://dashboard.stripe.com/test/apikeys
# TEST Keys beginnen mit pk_test_ / sk_test_
# LIVE Keys beginnen mit pk_live_ / sk_live_ (nur Production!)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."

# Stripe Webhook Secret
# Lokal: Wird von "stripe listen" ausgegeben
# Production: Stripe Dashboard → Developers → Webhooks → Signing Secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional: Resend (Email)
# Benötigt für: Welcome-Emails, Zahlungsbestätigungen, Daily-Digest
# Hole von: https://resend.com/api-keys
# RESEND_API_KEY="re_..."

# Optional: Platform Configuration
# Plattformgebühr in Prozent (default: 1.4%)
# ZIPAYO_PLATFORM_FEE_PERCENT="1.4"

# Optional: Feature Flags
# NODE_ENV="development"  # development | production | test
